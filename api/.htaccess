# api/.htaccess - protect config and sqlite files and disable directory listings
Options -Indexes

<IfModule mod_authz_core.c>
  <Files "config.php">
    Require all denied
  </Files>
  <FilesMatch "\.sqlite$">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
  <Files "config.php">
    Order allow,deny
    Deny from all
  </Files>
  <FilesMatch "\.sqlite$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
